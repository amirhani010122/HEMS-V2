# Application Settings
APP_NAME=EnergyIQ Backend
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=production

# Server
HOST=0.0.0.0
PORT=8000

# Database
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=energyiq_db

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production-12345678901234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Email (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# AI Settings
AI_FORECAST_MIN_DAYS=30
AI_FORECAST_CONFIDENCE_THRESHOLD=0.75
ANOMALY_DETECTION_SENSITIVITY=0.8
ANOMALY_Z_SCORE_THRESHOLD=3.0

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Features
ENABLE_AI_FEATURES=True
ENABLE_DEVICE_COMMANDS=True
ENABLE_AUDIT_LOGGING=True

# Data Retention
CONSUMPTION_DATA_RETENTION_DAYS=730
ALERT_DATA_RETENTION_DAYS=90
AUDIT_LOG_RETENTION_DAYS=365
